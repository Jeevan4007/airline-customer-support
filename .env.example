# Copy this file to `.env` and fill in your real values.

# ---------------- LLM provider ----------------
# Set ONE of the two. If OPENAI_API_KEY is set it takes precedence.
 OPENAI_API_KEY=Your-OpenAI-API-Key-Here

# Optional model override (defaults work for both providers)
LLM_MODEL=gpt-4o-mini                    # OpenAI default

# ---------------- Pinecone (RAG) ----------------
PINECONE_API_KEY=Pinecone-API-Key-Here
PINECONE_INDEX_NAME=airline-faq-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ---------------- PostgreSQL (Supabase) ----------------
# For the Supabase Session pooler, user MUST be `postgres.<project-ref>`.
PGHOST=aws-1-ap-northeast-1.pooler.supabase.com
PGPORT=5432
PGUSER=postgres.xustuowfczurewcfoodm
PGPASSWORD=PGPassword-Here
PGDATABASE=postgres
PGSSLMODE=require

# ---------------- Streamlit -> FastAPI ----------------
API_URL=http://localhost:8000
